{
  "ignoreCommand": "exit 0",
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "/api/sitemap"
    },
    {
      "source": "/sitemap-:sub.xml",
      "destination": "/api/sitemap?sub=:sub"
    },
    {
      "source": "/robots.txt",
      "destination": "/api/robots"
    },
    {
      "source": "/share",
      "destination": "/api/share"
    },
    {
      "source": "/api/send-otp",
      "destination": "/api/send-otp"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
